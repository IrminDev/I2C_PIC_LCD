  4553                           ;Config register CONFIG @ 0x2007
  4554                           ;	Oscillator Selection bits
  4555                           ;	FOSC = XT, XT oscillator
  4556                           ;	Watchdog Timer Enable bit
  4557                           ;	WDTE = OFF, WDT disabled
  4558                           ;	Power-up Timer Enable bit
  4559                           ;	PWRTE = ON, PWRT enabled
  4560                           ;	Brown-out Reset Enable bit
  4561                           ;	BOREN = ON, BOR enabled
  4562                           ;	Low-Voltage (Single-Supply) In-Circuit Serial Programming Enable bit
  4563                           ;	LVP = OFF, RB3 is digital I/O, HV on MCLR must be used for programming
  4564                           ;	Data EEPROM Memory Code Protection bit
  4565                           ;	CPD = OFF, Data EEPROM code protection off
  4566                           ;	Flash Program Memory Write Enable bits
  4567                           ;	WRT = OFF, Write protection off; all program memory may be written to by EECON control
  4568                           ;	In-Circuit Debugger Mode bit
  4569                           ;	DEBUG = 0x1, unprogrammed default
